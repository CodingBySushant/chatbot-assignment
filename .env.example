# ── LLM ──────────────────────────────────────────────────────────────────────
# Groq API Key — free tier at https://console.groq.com
# After signup: API Keys → Create API Key → copy the gsk_... value
GROQ_API_KEY=your_groq_api_key_here

# ── Qdrant (local mode — no Docker, no key needed) ────────────────────────────
QDRANT_PATH=./data/qdrant_db
COLLECTION_NAME=rag_corpus

# ── Models (downloaded once, cached to ~/.cache/huggingface/) ─────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── LLM model name on Groq ────────────────────────────────────────────────────
LLM_MODEL=llama-3.1-70b-versatile

# ── Chunking ──────────────────────────────────────────────────────────────────
# CHUNK_SIZE     : max tokens per passage (500–1000 recommended)
# CHUNK_OVERLAP  : overlap tokens between adjacent chunks (10–30% of chunk size)
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ── Retrieval ─────────────────────────────────────────────────────────────────
# TOP_K_RETRIEVE : how many ANN candidates to fetch from Qdrant
# TOP_K_RERANK   : how many to keep after cross-encoder reranking
TOP_K_RETRIEVE=20
TOP_K_RERANK=5

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
